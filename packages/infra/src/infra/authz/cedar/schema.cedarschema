entity LocalUser { id: String, role: String };
entity User { id: String };
entity Agent { id: String };
action create_agent appliesTo {
  principal: [LocalUser],
  resource:  [User],
  context: {
    currentCount: Long,
    maxAgents:    Long,
    isAdmin:      Bool,
    hardLimit:    Long,
  }
};
action access_agent appliesTo {
  principal: [LocalUser],
  resource:  [Agent],
  context: {
    intent:   String,
    archived: Bool,
  }
};
