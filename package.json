{
  "name": "presence-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/infra",
    "packages/server",
    "packages/tui",
    "packages/web"
  ],
  "scripts": {
    "test": "node test/run.js",
    "start": "npm run start --workspace=@presence/server",
    "start:cli": "npm run start --workspace=@presence/tui",
    "dev:web": "npm run dev --workspace=@presence/web",
    "build:web": "npm run build --workspace=@presence/web"
  },
  "devDependencies": {
    "fast-check": "^4.6.0"
  }
}
