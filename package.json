{
  "name": "presence-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/infra",
    "packages/server",
    "packages/tui"
  ],
  "scripts": {
    "test": "node test/run.js",
    "test:live": "node test/e2e/tui-live.test.js",
    "scenarios:mock": "node packages/tui/test/scenarios/index.js",
    "start": "npm run start --workspace=@presence/server",
    "start:cli": "npm run start --workspace=@presence/tui",
    "tui": "npm run start --workspace=@presence/tui",
    "server:start": "scripts/server.sh start",
    "server:stop": "scripts/server.sh stop",
    "server:status": "scripts/server.sh status",
    "server:restart": "scripts/server.sh restart",
    "server:logs": "scripts/server.sh logs",
    "user": "node packages/infra/src/infra/auth/cli.js",
    "lint": "eslint \"packages/*/src/**/*.js\"",
    "lint:check": "eslint --max-warnings 0 \"packages/*/src/**/*.js\""
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-plugin-sonarjs": "^4.0.3",
    "fast-check": "^4.6.0",
    "globals": "^17.5.0"
  }
}
