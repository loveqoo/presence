{
  "name": "presence-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/infra",
    "packages/server",
    "packages/tui"
  ],
  "scripts": {
    "test": "node test/run.js",
    "test:live": "node test/e2e/tui-live.test.js",
    "start": "npm run start --workspace=@presence/server",
    "start:cli": "npm run start --workspace=@presence/tui",
    "user": "node packages/infra/src/infra/auth/cli.js",
    "complexity": "node scripts/complexity.js",
    "complexity:check": "node scripts/complexity.js --check"
  },
  "devDependencies": {
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "fast-check": "^4.6.0"
  }
}
