{
  "name": "presence-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/infra",
    "packages/server",
    "packages/orchestrator",
    "packages/tui",
    "packages/web"
  ],
  "scripts": {
    "test": "node test/run.js",
    "test:live": "node test/e2e/multi-instance-live.test.js && node test/e2e/tui-live.test.js && cd packages/web && npx playwright test --config=playwright.live.config.js",
    "start": "npm run start --workspace=@presence/orchestrator",
    "start:server": "npm run start --workspace=@presence/server",
    "start:cli": "npm run start --workspace=@presence/tui",
    "dev": "npm run start & npm run dev --workspace=@presence/web",
    "dev:web": "npm run dev --workspace=@presence/web",
    "build:web": "npm run build --workspace=@presence/web",
    "user": "node packages/infra/src/infra/auth-cli.js"
  },
  "devDependencies": {
    "fast-check": "^4.6.0"
  }
}
